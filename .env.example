# Zkopíruj do .env.local a doplň hodnoty ze Supabase dashboardu:
#   Project Settings → API  (URL a publishable/anon klíč).
# Publishable klíč je určený do prohlížeče (není tajný), přesto .env.local
# není ve verzování — každý si ho vytvoří sám.

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
